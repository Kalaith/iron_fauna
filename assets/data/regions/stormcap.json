      "npcs": [
        {
          "id": "warden_teklan",
          "x": 15,
          "y": 7,
          "name": "Warden Teklan",
          "dialogue": [
            {
              "lines": [
                "It's grinding again up there. Someone we fed and sheltered decided the old sparks were worth another try. Go end it."
              ],
              "when": {
                "relapsed": [
                  "the_spire",
                  true
                ]
              }
            },
            {
              "lines": [
                "The Spire's quiet. First silence in living memory. My knees ache with the missing thunder."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Purge"
                ]
              }
            },
            {
              "lines": [
                "Green on the terraces. Green! And every herder eyeing that live machine like it owes them a warmer winter."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Reseed"
                ]
              }
            },
            {
              "lines": [
                "You keep the Spire now. The storms answer a hand again. Whose, though \u2014 that's the part that keeps me up."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Bind"
                ]
              }
            },
            {
              "lines": [
                "You climbed all this way \u2014 take this off my wall. Pulled it from a storm-unit that cost me two good herders. It should ride with someone going up."
              ],
              "when": {
                "flags_none": [
                  "stormcap_gift"
                ]
              },
              "set_flags": [
                "stormcap_gift"
              ],
              "give_grafts": [
                "arc_whip"
              ]
            },
            {
              "lines": [
                "Windward Hold has held the ridge since before the maps. We thin what the Spire throws down, and we bury our own quiet."
              ],
              "set_flags": [
                "stormcap_warden"
              ]
            }
          ]
        }
      ],
      "settlement": "windward_hold"
    },
