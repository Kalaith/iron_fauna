      "npcs": [
        {
          "id": "climber_isolde",
          "x": 24,
          "y": 7,
          "name": "Climber Isolde",
          "dialogue": [
            {
              "lines": [
                "The shelf's crawling with grafted things again \u2014 and these ones weren't born up there, they were MADE. By us. By what we brought back."
              ],
              "when": {
                "relapsed": [
                  "the_spire",
                  true
                ]
              }
            },
            {
              "lines": [
                "The doors are cold now. I put my palm on them just to be sure. Cold as a settled grave."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Purge"
                ]
              }
            },
            {
              "lines": [
                "The doors breathe warm and slow. Like something sleeping that could wake. I don't sleep near them anymore."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Reseed"
                ]
              }
            },
            {
              "lines": [
                "Your doors now. You open them and things walk out that answer to you. I've stopped asking what."
              ],
              "when": {
                "verdict": [
                  "the_spire",
                  "Bind"
                ]
              }
            },
            {
              "lines": [
                "Everything the Spire births comes down this shelf. I count them so the Hold knows what's coming. Lately I've had time to count clouds too."
              ]
            }
          ]
        }
      ]
    }
