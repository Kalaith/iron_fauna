      "npcs": [
        {
          "id": "rim_warden_brami",
          "x": 12,
          "y": 13,
          "name": "Rim-Warden Brami",
          "dialogue": [
            {
              "when": { "relapsed": ["the_kiln", true] },
              "lines": [
                "The doors are open and the tally's started again. Three in since the smoke turned. None out.",
                "You knew the way once. I'll hold your name off the list until you're back."
              ]
            },
            {
              "when": { "heart_defeated": "the_kiln" },
              "lines": [
                "First watch in thirty years I've counted stars instead of tremors.",
                "I don't know what to do with my hands now. I'll learn. That's the whole job — learning what the quiet asks of you."
              ]
            },
            {
              "lines": [
                "Past those doors is the Kiln. It grew things that swim in lava and don't notice arrows. I keep the tally of who goes in.",
                "The tally of who comes out is a shorter list. Shout your name on the way past so I spell it right."
              ]
            }
          ]
        },
        {
          "id": "vess_ashwalker",
          "x": 26,
          "y": 13,
          "name": "Vess the Ashwalker",
          "dialogue": [
            {
              "when": { "flags_none": ["ashvein_gift"] },
              "lines": [
                "Found a war-unit dead in the drifts last month — old one, Kiln-pattern, quill rack still warm. Took me a week to cut it free.",
                "I don't run a chassis big enough to bear it, and scrap-men ask questions. You look like the answer. Take it."
              ],
              "set_flags": ["ashvein_gift"],
              "give_grafts": ["quill_volley"]
            },
            {
              "lines": [
                "I walk the ashfields after each fall and take what the mountain buries. It's not grave-robbing if the grave is everywhere.",
                "Careful in the drifts. Things sleep shallow out here."
              ]
            }
          ]
        }
      ]
    }
