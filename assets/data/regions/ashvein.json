      ],
      "npcs": [
        {
          "id": "cinder_farmer_osk",
          "x": 20,
          "y": 13,
          "name": "Osk the Cinder-Farmer",
          "dialogue": [
            {
              "when": { "relapsed": ["the_kiln", true] },
              "lines": [
                "The fall came down greasy last night. That's not the mountain — that's the Kiln, breathing again.",
                "Whatever you settled down there, somebody unsettled it. My fields can wait. Go."
              ]
            },
            {
              "when": { "verdict": ["the_kiln", "Purge"] },
              "lines": [
                "No fall since you silenced it. Clean sky, first time in my life.",
                "Turns out the barley wanted the ash more than I did. Quiet's a kind of famine, rider. Nobody warns you about that."
              ]
            },
            {
              "when": { "verdict": ["the_kiln", "Reseed"] },
              "lines": [
                "The fall comes down soft now, and warm, and the barley's never stood taller.",
                "I keep waiting for the catch. My grandmother said the mountain never gives — it lends."
              ]
            },
            {
              "lines": [
                "You farm ash by trusting it. Three falls a season, soft as snow, and the barley comes up black-stemmed and sweet.",
                "The mountain isn't angry. It's just not finished. Neither am I, so we get along.",
                "East along the road is Glasshearth. Mind the drifts — things sleep shallow under fresh fall."
              ],
              "set_flags": ["ashvein_met_osk"]
            }
          ]
        }
      ]
    },
