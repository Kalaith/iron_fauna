      "npcs": [
        {
          "id": "steward_mire",
          "x": 16,
          "y": 7,
          "name": "Steward Mire",
          "dialogue": [
            {
              "lines": [
                "The reeds are full of grafted things again \u2014 home-made ones. We revived this rot and somebody used it as a recipe. Go to the heart and unmake them."
              ],
              "when": {
                "relapsed": [
                  "the_bloom",
                  true
                ]
              }
            },
            {
              "lines": [
                "The Bloom's gone cold and the water with it. Clean, they say. Dead-clean. The lanterns don't glow anymore \u2014 nothing to feed on."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Purge"
                ]
              }
            },
            {
              "lines": [
                "The fen's digesting sweetness for once. Fish came back fat. And every stilt-hand watches that live Bloom like it might teach them a shortcut."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Reseed"
                ]
              }
            },
            {
              "lines": [
                "You keep the Bloom. You decide what it dissolves and what it grows. The swamp always did have a keeper. Now it has a face."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Bind"
                ]
              }
            },
            {
              "lines": [
                "Take this before you go south. Cut it out of a Bloom-thing that nearly digested my nephew. It heals whoever wears the beast \u2014 pass it on."
              ],
              "when": {
                "flags_none": [
                  "sporefen_gift"
                ]
              },
              "set_flags": [
                "sporefen_gift"
              ],
              "give_grafts": [
                "cradle_gland"
              ]
            },
            {
              "lines": [
                "Stiltmarket floats because the Bloom hasn't decided to sink it yet. We trade, we duel, we keep our feet dry and our debts drier."
              ],
              "set_flags": [
                "sporefen_steward"
              ]
            }
          ]
        }
      ],
      "settlement": "stiltmarket"
    },
