      "npcs": [
        {
          "id": "gravedigger_oon",
          "x": 22,
          "y": 7,
          "name": "Gravedigger Oon",
          "dialogue": [
            {
              "lines": [
                "They're grafting in the deep fen again. I've been digging graves for the new keeper's cast-offs all week. Go put a stop to the grafting, not just the graves."
              ],
              "when": {
                "relapsed": [
                  "the_bloom",
                  true
                ]
              }
            },
            {
              "lines": [
                "Nothing rots here now. Do you understand what that means? I'm a gravedigger with nothing to dig. Peace put me out of work and I still can't celebrate."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Purge"
                ]
              }
            },
            {
              "lines": [
                "The Bloom's soft-lit again, breathing spores like a sleeper. Pretty. I've buried enough to distrust pretty."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Reseed"
                ]
              }
            },
            {
              "lines": [
                "Your Bloom. You choose what it eats. I'll keep a plot ready anyway \u2014 keepers of that machine tend to need one, in time."
              ],
              "when": {
                "verdict": [
                  "the_bloom",
                  "Bind"
                ]
              }
            },
            {
              "lines": [
                "This causeway's built on what the Bloom couldn't digest. Walk soft. Some of it remembers being someone."
              ]
            }
          ]
        }
      ]
    }
