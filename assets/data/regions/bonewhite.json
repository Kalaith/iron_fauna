      "npcs": [
        {
          "id": "pilgrim_sabel",
          "x": 24,
          "y": 7,
          "name": "Pilgrim Sabel",
          "dialogue": [
            {
              "lines": [
                "The relapse reached even here. The first place. If the Maw can slide back, nothing you've built is safe. Go, and this time understand what you're choosing."
              ],
              "when": {
                "relapsed": [
                  "the_maw",
                  true
                ]
              }
            },
            {
              "lines": [
                "I walked a thousand miles to see the first womb die. I thought I'd feel triumph. I felt like I'd buried my own grandmother, and I never met her."
              ],
              "when": {
                "verdict": [
                  "the_maw",
                  "Purge"
                ]
              }
            },
            {
              "lines": [
                "The oldest ruin is growing MOSS, rider. I've prayed at a hundred dead shrines and this is the first that ever answered."
              ],
              "when": {
                "verdict": [
                  "the_maw",
                  "Reseed"
                ]
              }
            },
            {
              "lines": [
                "You kept the Progenitors' own first machine. I don't know whether to kneel to you or run. I think that's the correct response to what you are now."
              ],
              "when": {
                "verdict": [
                  "the_maw",
                  "Bind"
                ]
              }
            },
            {
              "lines": [
                "These ruins are the Progenitors' own. Look at the doorways \u2014 built for people. They lived here, loved here, and made the thing that ate them here. Same as us."
              ]
            }
          ]
        }
      ]
    }
